# Free LLM options (works automatically with Pollinations if online):

# Option 1: Pollinations (DEFAULT, no setup, free, no API key)
# Already enabled — uses text.pollinations.ai when Ollama/Gemini unavailable

# Option 2: Ollama (100% free, local, better privacy)
# Download from https://ollama.com then run:
#   ollama pull llama3.2
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Option 3: Google Gemini (free tier, get key at https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your_free_key_here
# GEMINI_MODEL=gemini-2.0-flash
